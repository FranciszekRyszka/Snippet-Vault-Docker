# Copy to .env and adjust as needed (docker compose reads .env automatically).

# Absolute path to the SQLite database file inside the container.
# The parent directory is created on first boot and should be on a volume.
DATABASE_PATH=/app/data/snippets.db

# Port the server listens on inside the container (also update the compose
# "ports" mapping if you change this).
PORT=3000

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# REQUIRED. Secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# or:  openssl rand -base64 32
AUTH_SECRET=

# REQUIRED in production. The app's public URL (used for OAuth callbacks).
# Local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# The email granted the admin role. If unset, the FIRST account created becomes
# the admin. Existing (pre-auth) snippets are adopted by the admin on first login.
ADMIN_EMAIL=

# Allow visitors to self-register a password account ("true"/"false").
# Default false: accounts are created by an admin via the dashboard.
ALLOW_SELF_REGISTRATION=false

# Optional comma-separated allowlist of who may sign in. Leave empty for no
# restriction. When set, only these addresses can sign in via OAuth — plus
# ADMIN_EMAIL and anyone who already has an account (admin-created users are
# never locked out). Example: ALLOWED_EMAILS=me@example.com,teammate@example.com
ALLOWED_EMAILS=

# --- OAuth providers (optional) --------------------------------------------
# Each provider's button appears only when BOTH its id and secret are set.
#
# GitHub:  https://github.com/settings/developers  (New OAuth App)
#   Authorization callback URL:  <AUTH_URL>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
#
# Google:  https://console.cloud.google.com/apis/credentials  (OAuth client ID)
#   Authorized redirect URI:     <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
